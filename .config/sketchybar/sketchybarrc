fi

PADDING=4
FONT="Hack Nerd Font"
#FONT_LABEL=
#FONT_ICON=
THEME=2 # 1 = Dracula, 2 = Catppuccin Frappe, 3 = Catppuccin Mocha
#BAR_TYPE=1 # 1 = , 2 =
bar_defaults=(
    color=$BAR_COLOR
    border_color=$BORDER_COLOR
    position=top
    height=$($HOME/.config/sketchybar/helpers/get_menu_bar_height)
    margin=-2
    y_offset=-2
    corner_radius=0
    border_width=2
    blur_radius=30
    padding_left=15
    padding_right=15
    notch_width=200
    notch_offset=0
    display=main
    hidden=off
    topmost=off
    sticky=on
    font_smoothing=off
    shadow=off
)
icon_defaults=(
    icon.color=$ICON_COLOR
    icon.font="$FONT:Bold:17.0"
    icon.padding_left=$PADDING
    icon.padding_right=$PADDING
)
label_defaults=(
    label.color=$LABEL_COLOR
    label.font="$FONT:Semibold:13.0"
    label.padding_left=$PADDING
    label.padding_right=$PADDING
)
background_defaults=(
    background.height=26
    background.corner_radius=9
    background.border_width=2
    #background.padding_left=$PADDING
    #background.padding_right=$PADDING
)
popup_defaults=(
    #popup.height=30
    popup.background.border_width=2
    popup.background.corner_radius=9
    popup.background.color=$POPUP_COLOR
    popup.background.border_color=$POPUP_BORDER_COLOR
    #popup.horizontal=false
    #popup.background.shadow.drawing=on
    #popup.blur_radius=20
)
sketchybar --bar "${bar_defaults[@]}"
sketchybar --default updates=when_shown \
    "${icon_defaults[@]}" \
    "${label_defaults[@]}" \
    "${background_defaults[@]}" \
    "${popup_defaults[@]}"

source "$PLUGIN_DIR/spaces/item.sh"

