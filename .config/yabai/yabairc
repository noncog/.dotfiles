#!/usr/bin/env sh
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

yabai -m config debug_output on

yabai -m config layout bsp

yabai -m config top_padding    10
yabai -m config bottom_padding 10
yabai -m config left_padding   10
yabai -m config right_padding  10
yabai -m config window_gap     10

yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Open Cycle Time$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Barrier$" manage=off

yabai -m rule --add app="^Emacs$" space=^1
yabai -m rule --add app="^Firefox$" space=^2
yabai -m rule --add app="^(CLion|PyCharm)$" space=^3
yabai -m rule --add app="^Gimp$" space=^4
yabai -m rule --add app="^Blender$" space=^5
yabai -m rule --add app="^Anki$" space=^6
yabai -m rule --add app="^Tor Browser$" space=^7
yabai -m rule --add app="kitty" space=^8
yabai -m rule --add app="^Discord" space=^9

# yabai -m space 1 --label "Emacs"
# yabai -m space 2 --label "Safari"
# yabai -m space 8 --label "Kitty"

yabai -m signal --add event=window_destroyed app="^Firefox$" action="osascript -e 'quit app \"Firefox\"'" active=yes

yabai -m signal --add event=display_resized action="brew services restart sketchybar"

yabai -m signal --add event=window_destroyed app="^Emacs$" action="yabai -m display --focus 1" active=yes
