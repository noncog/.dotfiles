set $laptop eDP-1-1
set $external HDMI-0

# set mod key
set $mod Mod4

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# drag floaters key
floating_modifier $mod

# kill window
bindsym $mod+Shift+q kill

# window splitting moved to modes area

# change window layout mode
bindsym $mod+Tab layout tabbed
bindsym $mod+grave layout toggle split

# focus between floating and tiling
bindsym $mod+space focus mode_toggle

# make window float
bindsym $mod+Shift+space floating toggle

# hide scratchpad windows on focused workspace
bindsym $mod+semicolon [workspace="__focused__" floating] scratchpad show

# cycle through scratchpad windows
bindsym $mod+apostrophe [workspace="__focused__"] scratchpad show
# fullscreen
bindsym $mod+F11 fullscreen toggle

# emergency shutdown
bindsym $mod+Control+Delete exec --no-startup-id systemctl poweroff

focus_wrapping no

font pango:Fira Code 11

exec --no-startup-id nitrogen --restore

# class                 border  bground text    indicator child_border
client.focused          #6272A4 #6272A4 #F8F8F2 #6272A4   #6272A4
client.focused_inactive #44475A #44475A #F8F8F2 #44475A   #44475A
client.unfocused        #282A36 #282A36 #BFBFBF #282A36   #282A36
client.urgent           #44475A #FF5555 #F8F8F2 #FF5555   #FF5555
client.placeholder      #282A36 #282A36 #F8F8F2 #282A36   #282A36

client.background       #F8F8F2

# Necessary for i3-gaps to work properly (pixel can be any value)
for_window [class="^.*"] border pixel 2

# Smart Gaps
smart_gaps on
smart_gaps inverse_outer

# Smart Borders
smart_borders on

# Set inner/outer gaps
gaps inner 10
gaps outer 0

# name workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $code "Code"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3

# assign workspaces to monitors
workspace $ws1 output $external $laptop
workspace $ws2 output $external $laptop
workspace $ws3 output $laptop $external
workspace $code output $external $laptop

exec --no-startup-id emacs --daemon

exec --no-startup-id picom -b

exec --no-startup-id nm-applet

set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

bindsym $mod+Shift+z exec --no-startup-id ec4Linux change-state

exec_always --no-startup-id $HOME/.config/polybar/launch.sh

# note that exec_always runs every time you restart i3 not just initialization.
# this allows polybar to be restarted with i3 restarting.

# desktop app launcher
bindsym $mod+BackSpace exec --no-startup-id rofi -show drun -show-icons
# custom menu launcher
bindsym $mod+Escape exec --no-startup-id $HOME/.config/rofi/cogmenu/cogmenu.sh

exec --no-startup-id sleep 2 && profile=$(cat $HOME/.config/chemacs/profile) && emacsclient -c -s $profile &
exec --no-startup-id sleep 2 && firefox
exec --no-startup-id kitty --name Floating-Kitty
# restart i3 to make sure startup windows are moved to scratchpad
exec --no-startup-id restart

set $emacs "Emacs"
assign [class="Emacs"] $emacs	
workspace $emacs output $external $laptop
bindsym $mod+Control+Shift+e move container to workspace $emacs
bindsym $mod+Shift+e exec --no-startup-id $HOME/.config/rofi/rofi-chemacs/rofi-chemacs.sh
bindsym $mod+e [class="Emacs"] focus

set $firefox "Firefox"
assign [class="Firefox-esr"] $firefox
workspace $firefox output $external $laptop
bindsym $mod+Control+Shift+f move container to workspace $firefox
bindsym $mod+Shift+f exec --no-startup-id firefox
bindsym $mod+f [class="Firefox-esr" tiling] focus

assign [class="jetbrains-clion"] $code
bindsym $mod+Control+Shift+c move container to workspace $code
bindsym $mod+Shift+c exec --no-startup-id clion
bindsym $mod+c [class="jetbrains-clion"] focus

assign [class="jetbrains-pycharm"] $code
bindsym $mod+Control+Shift+p move container to workspace $code
bindsym $mod+Shift+p exec --no-startup-id pycharm
bindsym $mod+p [class="jetbrains-pycharm"] focus

assign [class="jetbrains-idea"] $code
bindsym $mod+Control+Shift+i move container to workspace $code
bindsym $mod+Shift+i exec --no-startup-id idea
bindsym $mod+i [class="jetbrains-idea"] focus

set $anki "Anki"
assign [class="Anki"] $anki
workspace $anki output $external $laptop
bindsym $mod+Control+Shift+a move container to workspace $anki
bindsym $mod+Shift+a exec --no-startup-id anki
bindsym $mod+a [class="Anki"] focus

for_window [instance="Floating-Kitty"] floating enable, resize set 50 ppt 50 ppt, move scratchpad, sticky enable
bindsym $mod+Shift+Return exec --no-startup-id kitty --name "Floating-Kitty"
bindsym $mod+Return [instance="Floating-Kitty"] scratchpad show, move position center

# NOTE - changing size using shrink instead of set, this is the only way it would work...
for_window [instance="Floating-Ranger"] floating enable, resize set 50 ppt 50 ppt, move scratchpad, sticky enable
bindsym $mod+Shift+r exec --no-startup-id kitty --name "Floating-Ranger" -e ranger
bindsym $mod+r [instance="Floating-Ranger"] scratchpad show, move position center

for_window [instance="Floating-Vim"] floating enable, resize set 50 ppt 50 ppt, move scratchpad, sticky enable
bindsym $mod+Shift+v exec --no-startup-id kitty --name "Floating-Vim" -e vim
bindsym $mod+v [instance="Floating-Vim"] scratchpad show, move position center

for_window [class="Tor Browser"] floating enable, resize set 75 ppt 75 ppt, move scratchpad, sticky enable
bindsym $mod+Shift+t exec --no-startup-id bash /opt/tor-browser_en-US/Browser/start-tor-browser
bindsym $mod+t [class="Tor Browser"] scratchpad show, move position center

for_window [class="discord"] floating enable, resize set 50 ppt 85 ppt, move scratchpad, sticky enable
for_window [class="discord"] move scratchpad, sticky enable, mark discord

bindsym $mod+Shift+d exec --no-startup-id discord
bindsym $mod+d [class="discord"] scratchpad show, move position center

for_window [class="Spotify"] floating enable, resize set 50 ppt 60 ppt, move scratchpad, sticky enable
bindsym $mod+Shift+s exec --no-startup-id spotify
bindsym $mod+s [class="Spotify"] scratchpad show, move position center

for_window [class="Nitrogen"] floating enable, resize set 50 ppt 50 ppt, move scratchpad, sticky enable, scratchpad show, move position center

set $resize_mode Resize: (-), (+), (Shift -), (Shift +)
mode "$resize_mode" {
     bindsym $mod+minus resize shrink width 10 px or 10 ppt
     bindsym $mod+equal resize grow width 10 px or 10 ppt
     bindsym $mod+Shift+minus resize shrink height 10 px or 10 ppt
     bindsym $mod+Shift+equal resize grow height 10 px or 10 ppt

     # back to normal
     bindsym $mod+Escape mode "default"
     bindsym $mod+BackSpace mode "default"
     bindsym $mod+Return mode "default"
     bindsym Escape mode "default"
     bindsym BackSpace mode "default"
     bindsym Return mode "default"
}
bindsym $mod+equal mode "$resize_mode"

set $split_mode Split: (v)ertically, (s)plit horizontally
mode "$split_mode" {
     bindsym $mod+v split h; mode "default"
     bindsym $mod+s split v; mode "default"
     bindsym v split h; mode "default"
     bindsym s split v; mode "default"

     # back to normal
     bindsym $mod+Escape mode "default"
     bindsym $mod+BackSpace mode "default"
     bindsym $mod+Return mode "default"
     bindsym Escape mode "default"
     bindsym BackSpace mode "default"
     bindsym Return mode "default"
}
bindsym $mod+w mode "$split_mode"

# Firefox: about:config > full-screen-api.ignore-widgets true

# NOTE: These dimensions are for i3-gaps, they will be different for i3.
set $yt_default_w 720
set $yt_default_h 407

# size
set $yt_d_w 720
set $yt_d_h 407
# location
set $yt_d_x 2910 px
set $yt_d_y 1023 px

# size
set $yt_l_w 636
set $yt_l_h 360
# location
set $yt_l_x 1274 px
set $yt_l_y 710 px

# set to your unique youtube page. ideally a page you will never visit.
# otherwise your firefox will be turned into the youtuber player...
set $youtube_page https://www.youtube.com/premium
set $youtube_title "YouTube Premium - YouTube — Mozilla Firefox"   
# found using xprop

for_window [title=$youtube_title] floating enable, resize set $yt_default_w $yt_default_h, move position center
for_window [title=$youtube_title] move scratchpad, sticky enable, mark youtube
	   
set $youtube_mode (Y)outube, (L)aptop, (D)esktop
mode "$youtube_mode" {
     bindsym $mod+y exec --no-startup-id firefox --new-window $youtube_page; mode "default"
     bindsym $mod+l [con_mark="youtube"] focus, resize set $yt_l_w $yt_l_h, move position $yt_l_x $yt_l_y; mode "default"
     bindsym $mod+d [con_mark="youtube"] focus, resize set $yt_d_w $yt_d_h, move position $yt_d_x $yt_d_y; mode "default"
     
     # back to normal
     bindsym $mod+Escape mode "default"
     bindsym $mod+BackSpace mode "default"
     bindsym $mod+Return mode "default"
     bindsym Escape mode "default"
     bindsym BackSpace mode "default"
     bindsym Return mode "default"
}
bindsym $mod+Shift+y mode "$youtube_mode"
bindsym $mod+y [con_mark="youtube"] scratchpad show

# To find the name or keysym of the key to be used in this config use xev and press the key to get it's name.

