set $laptop eDP-1-1
set $external HDMI-0

# set Modifier key
set $mod Mod4

# drag floaters key
floating_modifier $mod

# make window float
bindsym $mod+Shift+space floating toggle

# focus between floating and tiling
bindsym $mod+space focus mode_toggle

# hide scratchpad windows on focused workspace
bindsym $mod+semicolon [workspace="__focused__" floating] scratchpad show

# cycle through scratchpad windows
bindsym $mod+apostrophe scratchpad show, move position center

# layout controls
bindsym $mod+Tab layout tabbed
bindsym $mod+grave layout toggle split

# fullscreen
bindsym $mod+F11 fullscreen toggle

# emergency shutdown
bindsym $mod+Control+Delete exec --no-startup-id systemctl poweroff

bindsym $mod+h exec --no-startup-id $HOME/.config/i3/emacs-i3-integration focus left
bindsym $mod+j exec --no-startup-id $HOME/.config/i3/emacs-i3-integration focus down
bindsym $mod+k exec --no-startup-id $HOME/.config/i3/emacs-i3-integration focus up
bindsym $mod+l exec --no-startup-id $HOME/.config/i3/emacs-i3-integration focus right

bindsym $mod+Shift+h exec $HOME/.config/i3/emacs-i3-integration move left
bindsym $mod+Shift+j exec $HOME/.config/i3/emacs-i3-integration move down
bindsym $mod+Shift+k exec $HOME/.config/i3/emacs-i3-integration move up
bindsym $mod+Shift+l exec $HOME/.config/i3/emacs-i3-integration move right

set $resize_mode Resize: h, j, k, l
mode "$resize_mode" {
    bindsym h exec --no-startup-id $HOME/.config/i3/emacs-i3-integration resize shrink width 10 px or 10 ppt
    bindsym j exec --no-startup-id $HOME/.config/i3/emacs-i3-integration resize shrink height 10 px or 10 ppt
    bindsym k exec --no-startup-id $HOME/.config/i3/emacs-i3-integration resize grow height 10 px or 10 ppt
    bindsym l exec --no-startup-id $HOME/.config/i3/emacs-i3-integration resize grow width 10 px or 10 ppt

    bindsym Shift+h exec --no-startup-id $HOME/.config/i3/emacs-i3-integration resize shrink width 100 px or 100 ppt
    bindsym Shift+j exec --no-startup-id $HOME/.config/i3/emacs-i3-integration resize shrink height 100 px or 100 ppt
    bindsym Shift+k exec --no-startup-id $HOME/.config/i3/emacs-i3-integration resize grow height 100 px or 100 ppt
    bindsym Shift+l exec --no-startup-id $HOME/.config/i3/emacs-i3-integration resize grow width 100 px or 100 ppt

    bindsym equal exec --no-startup-id $HOME/.config/i3/i3-emacs-balance-windows

    # back to normal
    bindsym Escape mode "default"
    bindsym BackSpace mode "default"
    bindsym Return mode "default"
    # back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "$resize_mode"

bindsym $mod+v exec --no-startup-id $HOME/.config/i3/emacs-i3-integration split h
bindsym $mod+s exec --no-startup-id $HOME/.config/i3/emacs-i3-integration split v

bindsym $mod+Shift+q exec --no-startup-id $HOME/.config/i3/emacs-i3-integration kill

focus_wrapping no
focus_follows_mouse no
mouse_warping output

font pango:Fira Code 11

exec --no-startup-id nitrogen --restore

# class                 border  bground text    indicator child_border
client.focused          #6272A4 #6272A4 #F8F8F2 #6272A4   #6272A4
client.focused_inactive #44475A #44475A #F8F8F2 #44475A   #44475A
client.unfocused        #282A36 #282A36 #BFBFBF #282A36   #282A36
client.urgent           #44475A #FF5555 #F8F8F2 #FF5555   #FF5555
client.placeholder      #282A36 #282A36 #F8F8F2 #282A36   #282A36

client.background       #F8F8F2

# Necessary for i3-gaps to work properly (pixel can be any value)
for_window [class="^.*"] border pixel 3

# Smart Gaps
smart_gaps on
smart_gaps inverse_outer

# Smart Borders
smart_borders on

# Set inner/outer gaps
gaps inner 10
gaps outer 0

# name workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $code "Code"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3

# assign workspaces to monitors
workspace $ws1 output $external $laptop
workspace $ws2 output $external $laptop
workspace $ws3 output $laptop $external
workspace $code output $external $laptop

# desktop app launcher
bindsym $mod+BackSpace exec --no-startup-id rofi -show drun -show-icons
# cogmenu - custom menu launcher
bindsym $mod+Escape exec --no-startup-id $HOME/.config/rofi/cogmenu/cogmenu.sh

bindsym $mod+Shift+question exec --no-startup-id screenkey

bindsym $mod+Shift+z exec --no-startup-id ec4Linux change-state

exec --no-startup-id emacs --daemon

exec --no-startup-id picom -b

set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

exec --no-startup-id nm-applet

exec_always --no-startup-id $HOME/.config/polybar/launch.sh

# emacs
exec --no-startup-id sleep 3 && profile=$(cat $HOME/.config/chemacs/profile) && emacsclient -c -s $profile &

# firefox
exec --no-startup-id sleep 4 && firefox

# kitty
exec --no-startup-id kitty --name Floating-Kitty

bindsym $mod+Shift+g exec --no-startup-id gimp
bindsym $mod+g [title="GNU Image Manipulation Program"] focus

bindsym $mod+Shift+e exec --no-startup-id $HOME/.config/rofi/rofi-chemacs/rofi-chemacs.sh
bindsym $mod+e [class="Emacs"] focus
assign [class="Emacs"] $ws1

bindsym $mod+Shift+f exec --no-startup-id firefox
bindsym $mod+f [class="Firefox-esr" tiling] focus
assign [class="Firefox-esr"] $ws1

bindsym $mod+Shift+c exec --no-startup-id clion
bindsym $mod+c [class="jetbrains-clion"] focus

bindsym $mod+Shift+p exec --no-startup-id pycharm
bindsym $mod+p [class="jetbrains-pycharm"] focus

bindsym $mod+Shift+i exec --no-startup-id idea
bindsym $mod+i [class="jetbrains-idea"] focus

bindsym $mod+Shift+a exec --no-startup-id anki
bindsym $mod+a [class="Anki"] focus

for_window [class="kitty"] move scratchpad, sticky enable
bindsym $mod+Shift+Return exec --no-startup-id kitty
bindsym $mod+Return [class="kitty"] scratchpad show, resize set 50 ppt 50 ppt, move position center

for_window [class="Tor Browser"] move scratchpad, sticky enable
bindsym $mod+Shift+t exec --no-startup-id bash /opt/tor-browser_en-US/Browser/start-tor-browser
bindsym $mod+t [class="Tor Browser"] scratchpad show, resize set 75 ppt 75 ppt, move position center

for_window [class="discord"] move scratchpad, sticky enable
bindsym $mod+Shift+d exec --no-startup-id discord
bindsym $mod+d [class="discord"] scratchpad show, resize set 50 ppt 85 ppt, move position center

for_window [class="Spotify"] move scratchpad, sticky enable
bindsym $mod+Shift+m exec --no-startup-id spotify
bindsym $mod+m [class="Spotify"] scratchpad show, resize set 50 ppt 60 ppt, move position center

# values found using xprop
set $youtube_page https://www.youtube.com/premium
set $youtube_title "YouTube Premium - YouTube — Mozilla Firefox"

# size
set $yt_d_w 720
set $yt_d_h 407

# location
set $yt_d_x 2910 px
set $yt_d_y 1023 px

# size
set $yt_l_w 636
set $yt_l_h 360

# location
set $yt_l_x 1274 px
set $yt_l_y 710 px

for_window [title=$youtube_title] move scratchpad, sticky enable, mark youtube

bindsym $mod+Shift+y exec --no-startup-id firefox --new-window $youtube_page

bindsym $mod+y exec --no-startup-id "if [ -z $(xrandr --listmonitors | grep HDMI) ]; then i3-msg \\"[con_mark=youtube] scratchpad show, resize set $yt_l_w $yt_l_h, move position $yt_l_x $yt_l_y\\"; else i3-msg \\"[con_mark=youtube] scratchpad show, resize set $yt_d_w $yt_d_h, move position $yt_d_x $yt_d_y\\"; fi"

for_window [class="Nitrogen"] move scratchpad, sticky enable, scratchpad show, resize set 50 ppt 50 ppt, move position center

# To find the name or keysym of the key to be used in this config use xev and press the key to get it's name.

# To find window related information use:
# xprop and xwininfo
