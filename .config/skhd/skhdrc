alt - h [
  *      : yabai -m window --focus west
  "Emacs" ~
]
alt - j  [
  *      : yabai -m window --focus south
  "Emacs" ~
]
alt - k  [
  *      : yabai -m window --focus north
  "Emacs" ~
]
alt - l  [
  *      : yabai -m window --focus east
  "Emacs" ~
]

shift + alt - h : yabai -m window --swap west
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - l : yabai -m window --swap east

shift + alt + cmd - h : yabai -m window --warp west
shift + alt + cmd - j : yabai -m window --warp south
shift + alt + cmd - k : yabai -m window --warp north
shift + alt + cmd - l : yabai -m window --warp east

alt - s  [
  *      : yabai -m window --toggle split
  "Emacs" ~
]
alt - v  [
  *      : yabai -m window --toggle split
  "Emacs" ~
]

shift + alt - q  [
  *      : yabai -m window --close
  "Emacs" ~
]

shift + alt - space : yabai -m window --toggle float

alt - 1 : yabai -m space --focus 1
shift + alt - 1 : yabai -m window --space 1
alt - 2 : yabai -m space --focus 2
shift + alt - 2 : yabai -m window --space 2
alt - 3 : yabai -m space --focus 3
shift + alt - 3 : yabai -m window --space 3

alt - f11 : yabai -m window --toggle zoom-fullscreen

alt - 0x18  [
  *      : yabai -m space --balance
  "Emacs" ~
]

alt - e : yabai -m space --focus 1
shift + alt - e : emacs --with-profile $(cat "$HOME"/.config/chemacs/profile)
cmd + shift + alt - e : yabai -m window --space 1; yabai -m space --focus 1

alt - f : yabai -m space --focus 2
shift + alt - f : export MOZ_DISABLE_SAFE_MODE_KEY=1; /opt/homebrew/bin/librewolf -profile $HOME/.config/firefox/noncog
cmd + shift + alt - f : yabai -m window --space 2; yabai -m space --focus 2

alt - t : yabai -m space --focus 2
shift + alt - t : open -n -a "Tor Browser"
cmd + shift + alt - t : yabai -m window --space 2; yabai -m space --focus 2

alt - c : yabai -m space --focus 3
shift + alt - c : open -n -a "CLion"
cmd + shift + alt - c : yabai -m window --space 3; yabai -m space --focus 3

alt - b : yabai -m space --focus 5
shift + alt - b : open -n -a "Blender"
cmd + shift + alt - b : yabai -m window --space 5; yabai -m space --focus 5

alt - return : $HOME/.config/yabai/scripts/scratchpad.sh kitty
shift + alt - return : $HOME/.config/yabai/scripts/launch_one_instance.sh "kitty" "open -n -a "kitty""

alt - d : $HOME/.config/yabai/scripts/scratchpad.sh Discord
shift + alt - d : open -n -a "Discord"

alt - m : $HOME/.config/yabai/scripts/scratchpad.sh "Spotify"
shift + alt - m : open -n -a "Spotify"
